{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadIdentity",
      "Effect": "Allow",
      "Action": ["sts:GetCallerIdentity"],
      "Resource": "*"
    },
    {
      "Sid": "EcrAuthToken",
      "Effect": "Allow",
      "Action": ["ecr:GetAuthorizationToken"],
      "Resource": "*"
    },
    {
      "Sid": "EcrPushScoped",
      "Effect": "Allow",
      "Action": [
        "ecr:BatchGetImage",
        "ecr:BatchCheckLayerAvailability",
        "ecr:InitiateLayerUpload",
        "ecr:UploadLayerPart",
        "ecr:CompleteLayerUpload",
        "ecr:PutImage",
        "ecr:DescribeRepositories"
      ],
      "Resource": "arn:aws:ecr:{{AWS_REGION}}:{{AWS_ACCOUNT}}:repository/{{EXTENSION_NAME}}-handlers-ecs"
    },
    {
      "Sid": "EcsTaskDefinition",
      "Effect": "Allow",
      "Action": [
        "ecs:RegisterTaskDefinition",
        "ecs:DescribeTaskDefinition",
        "ecs:ListTaskDefinitions"
      ],
      "Resource": "*"
    },
    {
      "Sid": "LogsHandlers",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:DescribeLogGroups",
        "logs:PutRetentionPolicy"
      ],
      "Resource": "arn:aws:logs:{{AWS_REGION}}:{{AWS_ACCOUNT}}:log-group:/ecs/{{EXTENSION_NAME}}-handlers-ecs*"
    },
    {
      "Sid": "S3ResultsBucket",
      "Effect": "Allow",
      "Action": [
        "s3:GetBucketLocation",
        "s3:ListBucket",
        "s3:HeadBucket",
        "s3:CreateBucket",
        "s3:PutLifecycleConfiguration",
        "s3:GetLifecycleConfiguration",
        "s3:PutObject",
        "s3:GetObject",
        "s3:DeleteObject"
      ],
      "Resource": [
        "arn:aws:s3:::{{ECS_RESULTS_BUCKET}}",
        "arn:aws:s3:::{{ECS_RESULTS_BUCKET}}/*"
      ]
    },
    {
      "Sid": "PassEcsRoles",
      "Effect": "Allow",
      "Action": ["iam:PassRole"],
      "Resource": [
        "arn:aws:iam::{{AWS_ACCOUNT}}:role/{{EXTENSION_NAME}}-handlers-ecs-execution",
        "arn:aws:iam::{{AWS_ACCOUNT}}:role/{{EXTENSION_NAME}}-handlers-ecs-task"
      ],
      "Condition": {
        "StringEquals": {
          "iam:PassedToService": "ecs-tasks.amazonaws.com"
        }
      }
    },
    {
      "Sid": "LambdaHandlersOptional",
      "Effect": "Allow",
      "Action": [
        "lambda:GetFunction",
        "lambda:GetFunctionConfiguration",
        "lambda:UpdateFunctionCode",
        "lambda:UpdateFunctionConfiguration"
      ],
      "Resource": "arn:aws:lambda:{{AWS_REGION}}:{{AWS_ACCOUNT}}:function:{{EXTENSION_NAME}}-*"
    }
  ]
}
